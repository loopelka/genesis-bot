# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_telegram_user_id_here

# Products file (relative to project root)
PRODUCTS_FILE=products.xlsx

# Cache TTL in seconds (default: 300 = 5 min)
# Increase if you edit the file rarely; decrease for instant updates
CACHE_TTL=300

# FSM retention: prune abandoned checkout sessions (which hold customer PII)
# idle longer than FSM_TTL seconds (default: 86400 = 24h), swept every
# FSM_CLEANUP_INTERVAL seconds (default: 3600 = 1h). Set interval to 0 to disable.
FSM_TTL=86400
FSM_CLEANUP_INTERVAL=3600

# Directory for runtime state files (carts/users/orders/fsm_state.json).
# Default "." = project dir. On a host with an ephemeral filesystem (e.g.
# JustRunMyApp) set this to a mounted persistent volume, e.g. /data.
DATA_DIR=.
