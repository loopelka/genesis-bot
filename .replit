modules = ["python-3.12"]

[deployment]
# Reserved VM = exactly ONE always-on instance. Required for Telegram long
# polling: autoscale could run multiple replicas, and two pollers on the same
# BOT_TOKEN fight over getUpdates (409 Conflict) and produce inconsistent
# behavior. Do NOT change back to "autoscale".
deploymentTarget = "vm"
run = ["python", "main.py"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[[ports]]
localPort = 5000
externalPort = 5000
